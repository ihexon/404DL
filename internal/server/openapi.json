{
  "openapi": "3.1.0",
  "info": {
    "title": "404 Downloader Search API",
    "version": "1.0.0",
    "description": "Public HTTP API for searching files through configured 404 Downloader providers."
  },
  "servers": [
    {
      "url": "/",
      "description": "Current 404 Downloader server"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "operationId": "getHealth",
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "The server is ready to accept requests.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/search": {
      "get": {
        "operationId": "searchFiles",
        "summary": "Search files",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "description": "Search query.",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 200
            },
            "example": "linux interface"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of results to return. If omitted, 404 Downloader uses the configured server default limit.",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "example": 3
          },
          {
            "name": "provider",
            "in": "query",
            "required": false,
            "description": "Provider to query. Repeat this parameter to search multiple providers. If omitted, all configured providers are searched.",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/components/schemas/ProviderName"
              }
            },
            "style": "form",
            "explode": true,
            "example": [
              "knaben",
              "torrentclaw"
            ]
          },
          {
            "name": "X-4DL-Require-Encrypted",
            "in": "header",
            "required": false,
            "description": "Set to true to require an encrypted response body. The server returns 412 if response encryption is not configured.",
            "schema": {
              "type": "string",
              "const": "true"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results sorted by seeders descending.",
            "headers": {
              "X-Request-ID": {
                "$ref": "#/components/headers/RequestID"
              },
              "X-4DL-Encrypted": {
                "$ref": "#/components/headers/EncryptedResponse"
              },
              "X-4DL-Encryption": {
                "$ref": "#/components/headers/ResponseEncryption"
              }
            },
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              },
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/EncryptedResponseBody"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "412": {
            "$ref": "#/components/responses/EncryptionRequired"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          },
          "502": {
            "$ref": "#/components/responses/ProviderError"
          }
        }
      }
    }
  },
  "components": {
    "headers": {
      "RequestID": {
        "description": "Request correlation ID generated by 404 Downloader or accepted from the request.",
        "schema": {
          "type": "string"
        }
      },
      "EncryptedResponse": {
        "description": "Present with value true when the response body is encrypted.",
        "schema": {
          "type": "string",
          "const": "true"
        }
      },
      "ResponseEncryption": {
        "description": "Response body encryption format.",
        "schema": {
          "type": "string",
          "const": "aes-256-gcm-base64"
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request query parameters are invalid, including unknown providers.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestID"
          },
          "X-4DL-Encrypted": {
            "$ref": "#/components/headers/EncryptedResponse"
          },
          "X-4DL-Encryption": {
            "$ref": "#/components/headers/ResponseEncryption"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          },
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/EncryptedResponseBody"
            }
          }
        }
      },
      "EncryptionRequired": {
        "description": "The client required encrypted response bodies but the server is not configured with FOURDL_CRYKEY.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestID"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "ProviderError": {
        "description": "All configured upstream providers failed.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestID"
          },
          "X-4DL-Encrypted": {
            "$ref": "#/components/headers/EncryptedResponse"
          },
          "X-4DL-Encryption": {
            "$ref": "#/components/headers/ResponseEncryption"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          },
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/EncryptedResponseBody"
            }
          }
        }
      },
      "InternalServerError": {
        "description": "The server failed while preparing the response.",
        "headers": {
          "X-Request-ID": {
            "$ref": "#/components/headers/RequestID"
          },
          "X-4DL-Encrypted": {
            "$ref": "#/components/headers/EncryptedResponse"
          },
          "X-4DL-Encryption": {
            "$ref": "#/components/headers/ResponseEncryption"
          }
        },
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          },
          "text/plain": {
            "schema": {
              "$ref": "#/components/schemas/EncryptedResponseBody"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string",
            "const": "ok"
          }
        },
        "additionalProperties": false
      },
      "SearchResult": {
        "type": "object",
        "required": [
          "provider",
          "title",
          "seeders",
          "peers"
        ],
        "properties": {
          "provider": {
            "type": "string",
            "description": "Provider that returned the result."
          },
          "title": {
            "type": "string",
            "description": "Result title as normalized by 404 Downloader."
          },
          "bytes": {
            "type": "integer",
            "format": "int64",
            "minimum": 0,
            "description": "Content size in bytes when the provider supplies it."
          },
          "category": {
            "type": "string",
            "description": "Provider category when available."
          },
          "date": {
            "type": "string",
            "description": "Provider upload or publication date when available."
          },
          "seeders": {
            "type": "integer",
            "minimum": 0
          },
          "peers": {
            "type": "integer",
            "minimum": 0
          },
          "hash": {
            "type": "string",
            "description": "BitTorrent info hash when available."
          },
          "magnetUrl": {
            "type": "string",
            "description": "Magnet URL when available."
          }
        },
        "additionalProperties": false
      },
      "ProviderName": {
        "type": "string",
        "enum": [
          "knaben",
          "torrentclaw"
        ]
      },
      "EncryptedResponseBody": {
        "type": "string",
        "description": "Base64 AES-256-GCM encrypted JSON response body when the client requires encryption and the server is configured with FOURDL_CRYKEY."
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "$ref": "#/components/schemas/ErrorDetail"
          }
        },
        "additionalProperties": false
      },
      "ErrorDetail": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "enum": [
              "bad_request",
              "encryption_required",
              "provider_error",
              "internal_server_error"
            ]
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}
